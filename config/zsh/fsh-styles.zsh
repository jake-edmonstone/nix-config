# Dracula color palette for fast-syntax-highlighting.
# Sourced from modules/zsh.nix (mkOrder 1400, after the plugin body).
# Edits here require a rebuild — the file is store-pinned.

typeset -gA FAST_HIGHLIGHT_STYLES
FAST_HIGHLIGHT_STYLES[default]=none
FAST_HIGHLIGHT_STYLES[unknown-token]='fg=#FF5555,bold'
FAST_HIGHLIGHT_STYLES[reserved-word]='fg=#FF79C6'
FAST_HIGHLIGHT_STYLES[alias]='fg=#50FA7B'
