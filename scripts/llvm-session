#!/usr/bin/env bash
set -euo pipefail
INPUT="${*:?Usage: llvm-session.sh <name>}"

# Normalize: "fix decoder error" and "fix-decoder-error" both work
SLUG="${INPUT// /-}"          # spaces → hyphens (for dir, branch)
DISPLAY="${SLUG//-/ }"        # hyphens → spaces (for tmux session name)

SESSION="$DISPLAY"
DIR="$HOME/ws/llvm-project-$SLUG"
BRANCH="jakee/$SLUG"

if ! [ -d "$DIR" ]; then
  read -p "Directory $DIR does not exist. Create worktree? [y/N] " answer
  [[ "$answer" =~ ^[Yy]$ ]] || exit 1
  git -C "$HOME/ws/llvm-project" worktree add -b "$BRANCH" "$DIR" origin/cerebras --no-track
  cp "$HOME/ws/llvm-project/.clangd" "$DIR/.clangd" 2>/dev/null
fi

if ! tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux new-session -d -s "$SESSION" -c "$DIR"
  tmux rename-window -t "$SESSION:1" "claude"
  tmux send-keys -t "$SESSION:1" "claude" Enter

  tmux new-window -t "$SESSION" -n "editor" -c "$DIR"
  tmux send-keys -t "$SESSION:2" "nvim ." Enter

  tmux new-window -t "$SESSION" -n "lazygit" -c "$DIR"
  tmux send-keys -t "$SESSION:3" "lazygit" Enter

  tmux new-window -t "$SESSION" -n "shell" -c "$DIR"
  tmux send-keys -t "$SESSION:4" "fixpath" Enter

  tmux select-window -t "$SESSION:1"
fi

if [ -n "${TMUX:-}" ]; then
  tmux switch-client -t "$SESSION"
else
  tmux attach -t "$SESSION"
fi
