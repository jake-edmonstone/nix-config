#!/usr/bin/env bash
set -euo pipefail

# Tab-delimited format: "name\tmarker" — ensures names with spaces stay intact
# Current session gets a * marker, others get no marker
list_cmd="cur=\$(tmux display-message -p '#S') && {
  tmux list-sessions -f \"#{!=:#{session_name},\$cur}\" -F '#{session_last_attached} #{session_name}' | sort -nr | while IFS= read -r line; do printf '%s\n' \"\${line#* }\"; done
  printf '%s\t*\n' \"\$cur\"
}"

# nix-portable's proot ptrace-traps execve; fzf's `become` calls execve from a
# Go worker thread, which crashes the successor process with SIGSEGV at NULL
# before it can run. `execute-silent`+`abort` forks first, sidestepping it.
new_action="become(tmux new-session -ds {q} && tmux switch-client -t {q})"
[[ -n "${NP_RUNTIME:-}" ]] && new_action="execute-silent(tmux new-session -ds {q} && tmux switch-client -t {q})+abort"

sel=$(eval "$list_cmd" | fzf \
  --reverse \
  --no-sort \
  --ansi \
  --exit-0 \
  --delimiter '\t' \
  --with-nth '1,2' \
  --border-label ' Sessions ' \
  --header $'C-x kill    C-n new\nC-r rename  C-/ preview' \
  --color='header:#6272a4,label:#bd93f9' \
  --preview 'tmux capture-pane -t {1}: -ep 2>/dev/null || echo "(no pane)"' \
  --preview-window 'right:60%,noinfo,border-left,follow' \
  --bind 'ctrl-/:change-preview-window(hidden|right:60%)' \
  --bind "ctrl-x:execute-silent(cur=\$(tmux display-message -p '#S') && target={1} && if [ \"\$target\" = \"\$cur\" ]; then [ \"\$(tmux list-sessions | wc -l)\" -gt 1 ] && tmux switch-client -n && tmux kill-session -t \"\$target\"; else tmux kill-session -t \"\$target\"; fi)+reload($list_cmd)" \
  --bind "ctrl-r:execute(tmux-rename-session {1})+reload($list_cmd)" \
  --bind "ctrl-n:${new_action}")

# If empty or current session (marked with tab), nothing to switch to
[[ -z "$sel" || "$sel" == *$'\t'* ]] && exit 0
sel="${sel%%$'\t'*}"
tmux switch-client -t "$sel"
