#!/usr/bin/env bash
set -euo pipefail

TYPST_DIR="$HOME/typst"
WEBSITE_DIR="$HOME/Projects/jake-edmonstone.github.io"

COURSES=(pmath347 pmath367 pmath450 pmath352)

tmps=()
cleanup() { [ "${#tmps[@]}" -eq 0 ] || rm -f "${tmps[@]}"; }
trap cleanup EXIT

# Commit and push typst repo (only the course notes dirs — unstage anything
# else the user had queued so the commit is strictly scoped to these courses).
echo "Committing typst repo..."
git -C "$TYPST_DIR" reset --quiet
note_paths=()
for course in "${COURSES[@]}"; do
  note_paths+=("$course/notes")
done
git -C "$TYPST_DIR" add "${note_paths[@]}"
if git -C "$TYPST_DIR" diff --cached --quiet; then
  echo "No note changes in typst repo"
else
  git -C "$TYPST_DIR" commit -m "update notes $(date +%Y-%m-%d)"
fi
git -C "$TYPST_DIR" push

# Compile notes
pdfs=()
for course in "${COURSES[@]}"; do
  main="$TYPST_DIR/$course/notes/main.typ"
  output="$WEBSITE_DIR/${course}-notes.pdf"

  echo "Compiling $course..."

  # Insert 12pt text size for PDF output via temp file (avoids corrupting source on failure).
  # Temp file must be in the same directory so Typst resolves relative imports correctly.
  # BSD mktemp (macOS) requires the X's at the end of the template, so rename to add .typ.
  # Register $tmp_base with cleanup BEFORE mv so a failure between mktemp and mv doesn't leak.
  tmp_base="$(mktemp "$(dirname "$main")/.main_website.XXXXXX")"
  tmps+=("$tmp_base")
  tmp="$tmp_base.typ"
  mv "$tmp_base" "$tmp"
  tmps+=("$tmp")
  sed -e '/show: preamble/a\
#set text(12pt)
' "$main" > "$tmp"

  typst compile "$tmp" "$output"
  rm -f "$tmp"

  pdfs+=("${course}-notes.pdf")
done

# Commit and push website repo (only these course PDFs — unstage anything else first).
echo "Committing website repo..."
git -C "$WEBSITE_DIR" reset --quiet
git -C "$WEBSITE_DIR" add "${pdfs[@]}"
if git -C "$WEBSITE_DIR" diff --cached --quiet; then
  echo "No note PDF changes in website repo"
else
  git -C "$WEBSITE_DIR" commit -m "update notes $(date +%Y-%m-%d)"
fi
git -C "$WEBSITE_DIR" push

echo "Done!"
